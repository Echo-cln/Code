    <property name="styleSheet">
     <string notr="true">/* ====================== TreeWidget 整体样式 ====================== */
QTreeWidget {
    background-color: rgb(255, 226, 209); /* 淡黄色内容区背景 */
    border: 1px solid #FFD4D4;          /* 粉色边框 */
    border-radius: 6px;                 /* 圆角 */
    margin: 10px;                       /* 外边距 */
	font:bold 16px &quot;黑体&quot;;
}

/* ====================== TreeWidget 头部（列标题） ====================== */
QTreeWidget::header {
    background-color: #FFD4D4;          /* 粉色头部背景 */
    color: rgb(177, 108, 109);          /* 浅粉色文字（未选中节点的文字颜色基准） */
    font-weight: bold;                  /* 加粗 */
    padding: 6px;                       /* 头部内边距 */
	font:bold 16px &quot;黑体&quot;;
}

/* ====================== TreeWidget 普通节点（未选中状态） ====================== */
QTreeWidget::item {
    padding: 8px;                       /* 节点内边距 */
    border-bottom: 1px solid #FFF0E8;   /* 浅粉分隔线（可选） */
    color: rgb(177, 108, 109);          /* 显式设置未选中节点文字颜色（与头部文字一致） */
	font:bold 13px &quot;黑体&quot;;
}

/* ====================== TreeWidget 选中节点 ====================== */
QTreeWidget::item:selected {
    background-color: rgb(253, 206, 193); /* 深粉色选中背景（仅改背景，不改变文字颜色） */
    /* 移除或注释掉 color 属性，继承普通节点的文字颜色 */
    /* color: rgb(225, 198, 185); */     /* 可选：显式声明与普通节点一致（非必需） */
}</string>
    </property>
    <column>
     <property name="text">
      <string notr="true">1</string>
     </property>
    </column>
   </widget>
